{
  "$schema": "node_modules/wrangler/config-schema.json",
  "account_id": "ec0a9ef71c2605e8e98f56312162e5ee",
  "name": "mlhk-in",
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-09",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "binding": "ASSETS",
    "directory": ".open-next/assets"
  },
  "images": {
    "binding": "IMAGES"
  },
  "services": [
    {
      "binding": "WORKER_SELF_REFERENCE",
      "service": "mlhk-in"
    }
  ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "mlhk-in",
      "database_id": "fc5efe8e-bcc1-4941-8ddb-854b439f7002"
    }
  ],
  "kv_namespaces": [
    {
      "binding": "KV",
      "id": "9f882c8b500f421cb55d76fdc187c139"
    }
  ],
  "r2_buckets": [
    {
      "binding": "R2",
      "bucket_name": "mlhk-in"
    }
  ],
  "observability": { "enabled": true },
  "upload_source_maps": true
}
